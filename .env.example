# Copy to .env.local and fill in real values. Never commit .env.local.

# Neon Postgres connection string — use the POOLED connection string
# (Neon dashboard > Connect > check "Pooled connection"), since serverless
# functions open a fresh connection per invocation.
DATABASE_URL=

# Random secret for signing session cookies. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# Anthropic API key for AI-assisted grading drafts (Stage 4). Leave blank
# until then — the grading queue works fully manually without it.
ANTHROPIC_API_KEY=

# Seed admin account (created by db/seed.ts).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Vercel Blob storage for resource_list file uploads (Stage 2). Create via
# the Vercel dashboard: Project > Storage > Create Database > Blob, then
# copy the token from the store's ".env.local" tab.
BLOB_READ_WRITE_TOKEN=
